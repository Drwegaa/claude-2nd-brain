{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "mkdir -p {{VAULT_PATH}}/03-Daily && echo \"$(date '+%Y-%m-%d %H:%M') — session ended\" >> {{VAULT_PATH}}/03-Daily/.session-log.txt",
            "async": true
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "echo 'Context compacting — run /save-session to preserve to Obsidian'",
            "async": true
          }
        ]
      }
    ]
  }
}
